#!/bin/bash
# 只在 monitor / detector / mock 相關檔被 staged 時跑 mock selftest 回歸。
# 安裝: git config core.hooksPath scripts/git-hooks
set -e
staged=$(git diff --cached --name-only)
if echo "$staged" | grep -qE 'scripts/zhuli/(live_position_monitor|intraday_stage_helper|exit/|mock/|precompute_overnight)'; then
    echo "[pre-commit] monitor 邏輯異動 → 跑 mock selftest…"
    if ! PYTHONPATH=scripts python3 -m zhuli.mock.monitor_replay --selftest; then
        echo "[pre-commit] ❌ mock selftest 失敗、commit 中止。要跳過: git commit --no-verify"
        exit 1
    fi
    echo "[pre-commit] ✅ mock selftest 通過"
    # TUI L1+L2 (L3 結構快照也夠快、一起跑；snapshot SVG 才不進 pre-commit)
    echo "[pre-commit] TUI 異動 → 跑 tui_tests (L1+L2+L3)…"
    if ! PYTHONPATH=scripts python3 -m zhuli.mock.tui_tests; then
        echo "[pre-commit] ❌ tui_tests 失敗、commit 中止。要跳過: git commit --no-verify"
        exit 1
    fi
    echo "[pre-commit] ✅ tui_tests 通過"
    if ! PYTHONPATH=scripts python3 -m zhuli.mock.ws_tests; then
        echo "[pre-commit] ❌ ws_tests 失敗、commit 中止。"; exit 1
    fi
    echo "[pre-commit] ✅ ws_tests 通過"
fi
